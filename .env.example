# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

APP_NAME=LeadSpawn
ENVIRONMENT=development
DEBUG=true

# Optional: only needed if you switch the provider to Google Places later
GOOGLE_PLACES_API_KEY=

# PostgreSQL connection (async driver). Format:
# postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/leadspawn

# How long a cached search stays fresh before we re-query OpenStreetMap
CACHE_TTL_DAYS=30

# Google OAuth Web Client ID (Google Cloud Console -> Credentials)
GOOGLE_CLIENT_ID=

# Secret for signing session tokens — set a long random value in production
JWT_SECRET=change-me
